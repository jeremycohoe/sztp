## Force TLS 1.2 only for the sZTP bootstrap server (SBI).
##
## Cisco IOS-XE 17.18.x sZTP libcurl rejects TLS 1.3 (handshake dies
## immediately after the server cert is presented with libcurl
## CURLE_SSL_CONNECT_ERROR). Pin the server to TLS 1.2 with a permissive
## SECLEVEL so older Cisco crypto stacks negotiate.

openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
MinProtocol = TLSv1.2
MaxProtocol = TLSv1.2
CipherString = DEFAULT:@SECLEVEL=1
