<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

    <!-- Hostname -->
    <hostname>sztp-c9300x-pod27</hostname>

    <!-- Local user: admin / Cisco123 -->
    <username>
      <name>admin</name>
      <privilege>15</privilege>
      <secret>
        <encryption>0</encryption>
        <secret>Cisco123</secret>
      </secret>
    </username>

    <!-- AAA -->
    <aaa>
      <new-model/>
      <authentication>
        <login>
          <name>default</name>
          <a1><local/></a1>
        </login>
      </authentication>
      <authorization>
        <exec>
          <name>default</name>
          <a1><local/></a1>
        </exec>
      </authorization>
    </aaa>

    <!-- Management IP: Vlan1 10.1.1.101/24 -->
    <interface>
      <Vlan>
        <name>1</name>
        <ip>
          <address>
            <primary>
              <address>10.1.1.101</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
      </Vlan>
    </interface>

    <!-- Default route via SZTP server -->
    <ip>
      <route>
        <ip-route-interface-forwarding-list>
          <prefix>0.0.0.0</prefix>
          <mask>0.0.0.0</mask>
          <fwd-list>
            <fwd>10.1.1.3</fwd>
          </fwd-list>
        </ip-route-interface-forwarding-list>
      </route>
      <domain>
        <name>lab.local</name>
      </domain>
      <name-server>
        <no-vrf>
          <name>10.1.1.3</name>
        </no-vrf>
      </name-server>
      <ssh>
        <version>2</version>
      </ssh>
      <scp>
        <server>
          <enable/>
        </server>
      </scp>
    </ip>

    <!-- NTP pointing at SZTP server VM -->
    <ntp>
      <server>
        <server-list>
          <ip-address>10.1.1.3</ip-address>
        </server-list>
      </server>
    </ntp>

    <!-- Logging -->
    <logging>
      <buffered>
        <size>32000</size>
      </buffered>
      <host>
        <ipv4-host-list>
          <ipv4-host>10.1.1.3</ipv4-host>
        </ipv4-host-list>
      </host>
    </logging>

    <!-- Enable NETCONF-YANG -->
    <netconf-yang/>

    <!-- Enable RESTCONF -->
    <restconf/>

    <!-- Service timestamps -->
    <service>
      <timestamps>
        <debug>
          <datetime>
            <msec/>
          </datetime>
        </debug>
        <log>
          <datetime>
            <msec/>
          </datetime>
        </log>
      </timestamps>
    </service>

  </native>
</config>
