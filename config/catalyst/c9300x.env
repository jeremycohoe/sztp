# C9300X / C9500X (HA-SUDI / SHA-256 trust chain, circa-2020 and later).
#
# Usage:
#   docker-compose --env-file config/catalyst/c9300x.env --profile iosxe up -d

SZTP_URL=https://10.1.1.3:8080
SZTP_TRUST_ANCHOR=circa-2020

# Cisco SUDI subject serialNumber is the PID, not the chassis SN.
SZTP_DEVICE_SN=C9300X-24Y

SZTP_VOUCHER_FILE=/local_files/FCW2129G03A.vcj
SZTP_OWNER_CERT_FILE=/local_files/owner_cert_chain.cms
