# C9200 (pre-HA-SUDI, ACT2 / SHA-1 trust chain).
#
# Usage:
#   docker-compose --env-file config/catalyst/c9200.env --profile iosxe up -d
#
# Override any value from your shell environment:
#   SZTP_DEVICE_SN=FCW1234ABCD docker-compose --env-file ... up -d

SZTP_URL=https://10.1.1.3:8080
SZTP_TRUST_ANCHOR=act2-sudi

# Cisco SUDI subject serialNumber is the PID, not the chassis SN (see AGENTS.md §6).
SZTP_DEVICE_SN=C9200-24T

# Voucher + owner-cert chain for this device. Must chain to the voucher's
# pinned-domain-cert. Regenerate per device; see local_files/README.
SZTP_VOUCHER_FILE=/local_files/FCW2129G03A.vcj
SZTP_OWNER_CERT_FILE=/local_files/owner_cert_chain.cms
