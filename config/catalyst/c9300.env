# C9300 / C9300L (ACT2 / SHA-1 trust chain).
#
# Usage:
#   docker-compose --env-file config/catalyst/c9300.env --profile iosxe up -d

# Redirecter URL advertised in DHCP option 143.
#
# CRITICAL: scheme+host+port ONLY — no path. IOS-XE 17.18's sZTP client
# appends `/restconf/operations/ietf-sztp-bootstrap-server:get-bootstrapping-data`
# itself; if SZTP_URL also includes that path the request URL becomes doubled
# and sztpd answers 404 "Unrecognized RPC."
#
# Port 8080 = redirecter (returns redirect-information pointing at bootstrap on
# 9090). Port 9090 = bootstrap (returns signed CMS onboarding-information).
SZTP_URL=https://10.1.1.3:8080
SZTP_TRUST_ANCHOR=act2-sudi

# Cisco SUDI subject serialNumber is the PID, not the chassis SN.
SZTP_DEVICE_SN=C9300-24T

# Lab device on 10.1.1.55 (chassis SN FCW2126G05V).
SZTP_VOUCHER_FILE=/local_files/FCW2126G05V.vcj
SZTP_OWNER_CERT_FILE=/local_files/owner_cert_chain.cms
