# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

dist/

# Never commit private keys or MASA vouchers; use
# scripts/export-sanitized-bundle.sh to package for sharing.
*.key
*.vcj
local_files/*.key
local_files/*.der
local_files/*.srl
local_files/*.bak.*

# Local lab artifacts (Cisco SUDI chain, voucher, owner/PDC keys & certs).
# Treated as runtime-only secrets; never commit.
sztp_local_files/
